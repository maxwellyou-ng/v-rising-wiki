# Caddy handles Let's Encrypt automatically.

wiki.v-ris.ing {
	encode gzip

	# SEO: crawler policy + sitemap (regenerated by scripts/generate-sitemap.sh)
	handle /robots.txt {
		respond <<ROBOTS
			User-agent: *
			Allow: /
			Disallow: /index.php
			Disallow: /api.php
			Disallow: /w/Special:
			Disallow: /w/Special%3A
			Sitemap: https://wiki.v-ris.ing/images/sitemap/sitemap-index-vrising_wiki.xml
			ROBOTS 200
	}

	# Legacy /wiki/ links → canonical /w/
	@oldwiki path_regexp oldwiki ^/wiki/(.+)$
	redir @oldwiki /w/{re.oldwiki.1} permanent

	@wiki {
		path_regexp wiki ^/w/(.+)$
	}
	rewrite @wiki /index.php?title={re.wiki.1}&{query}

	reverse_proxy mediawiki:80
}

v-ris.ing, www.v-ris.ing {
	redir https://wiki.v-ris.ing{uri} permanent
}
